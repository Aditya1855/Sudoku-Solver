@page
@model IndexModel
@{
    ViewData["Title"] = "Sudoku Solver";
    int size = Model.SelectedType == "Mini4x4" ? 4 :
               Model.SelectedType == "Mini6x6" ? 6 : 9;
    int solvedSize = size;
    string sudokuClass = Model.SelectedType == "Classic" || Model.SelectedType == "Diagonal" ? "classic" :
                         Model.SelectedType == "Mini4x4" ? "mini4" :
                         Model.SelectedType == "Mini6x6" ? "mini6" : "";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: linear-gradient(to bottom right, #f0f4f8, #e0f7fa);
        min-height: 100vh;
    }

    .card {
        border-radius: 1rem;
        padding: 1.5rem;
        background-color: white;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    }

    .table-bordered {
        border-collapse: collapse !important;
        border-spacing: 0 !important;
        border: 3px solid black;
    }

        .table-bordered td {
            width: 45px;
            height: 45px;
            padding: 0;
            margin: 0;
            border: 1px solid #dee2e6;
        }

        .table-bordered input.form-control {
            border: none !important;
            border-radius: 0 !important;
            box-shadow: none !important;
            padding: 0;
            height: 100%;
            width: 100%;
            font-size: 20px;
            text-align: center;
            background-color: #f8f9fa;
        }

            .table-bordered input.form-control:hover,
            .table-bordered input.form-control:focus {
                background-color: #e3f2fd;
                border: 2px solid #0d6efd;
            }

    .classic .table-bordered td:nth-child(3n) {
        border-right: 3px solid black;
    }

    .classic .table-bordered tr:nth-child(3n) td {
        border-bottom: 3px solid black;
    }

    .mini4 .table-bordered td:nth-child(2n) {
        border-right: 3px solid black;
    }

    .mini4 .table-bordered tr:nth-child(2n) td {
        border-bottom: 3px solid black;
    }

    .mini6 .table-bordered td:nth-child(2n) {
        border-right: 3px solid black;
    }

    .mini6 .table-bordered tr:nth-child(3n) td {
        border-bottom: 3px solid black;
    }

    .table-bordered td:first-child {
        border-left: 3px solid black;
    }

    .table-bordered tr:first-child td {
        border-top: 3px solid black;
    }

    .diagonal {
        background-color: #e0f7fa !important;
    }

    .anti-diagonal {
        background-color: #fff3e0 !important;
    }

    input:invalid.form-control {
        background-color: #ffe6e6 !important;
        border: 2px solid #dc3545 !important;
        color: #dc3545;
    }


    .solved-cell {
        background-color: #e8f5e9;
        font-size: 20px;
        text-align: center;
    }

    .original-cell {
        font-weight: bold;
        color: #000;
    }

    .filled-cell {
        font-weight: normal;
        color: #6c757d;
    }

    .btn {
        font-weight: 500;
        letter-spacing: 0.5px;
    }

    footer {
        font-size: 0.85rem;
        color: #6c757d;
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow text-center @sudokuClass">
                <h2 class="mb-2">Sudoku Solver</h2>
                <p class="text-muted mb-4">Enter the puzzle and click Solve to see the solution</p>

                <form method="post">
                    <div class="mb-3">
                        <label for="SelectedType" class="form-label">Select Sudoku Type:</label>
                        <select asp-for="SelectedType" class="form-select" id="SelectedType" onchange="this.form.submit()">
                            <option value="Classic">Classic 9x9</option>
                            <option value="Mini4x4">Mini 4x4</option>
                            <option value="Mini6x6">Mini 6x6</option>
                            <option value="Diagonal">Diagonal Sudoku</option>
                        </select>
                    </div>

                    @{
                        string inputPattern = size == 4 ? "[1-4]" :
                        size == 6 ? "[1-6]" :
                        "[1-9]";
                    }

                    <table class="table table-bordered mx-auto">
                        @for (int i = 0; i < size; i++)
                        {
                            <tr>
                                @for (int j = 0; j < size; j++)
                                {
                                    string diagonalClass = "";
                                    if (Model.SelectedType == "Diagonal")
                                    {
                                        if (i == j) diagonalClass = "diagonal";
                                        else if (i + j == size - 1) diagonalClass = "anti-diagonal";
                                    }

                                    <td class="@diagonalClass">
                                        <input type="text"
                                               name="Puzzle[@i][@j]"
                                               maxlength="1"
                                               inputmode="numeric"
                                               pattern="@inputPattern"
                                               class="form-control text-center"
                                               value="@Model.InputPuzzle?[i][j]" />
                                    </td>
                                }
                            </tr>
                        }
                    </table>

                    <div class="d-flex justify-content-center gap-3 mt-3">
                        <button type="submit" asp-page-handler="Solve" class="btn btn-success px-4">Solve</button>
                        <button type="submit"
                                asp-page-handler="Clear"
                                class="btn btn-outline-secondary px-4"
                                formnovalidate>
                            Clear
                        </button>

                    </div>
                </form>

                @if (Model.ShowUnsolvableMessage)
                {
                    <div class="alert alert-danger mt-4">
                        @ViewData["Error"]  "This Sudoku puzzle cannot be solved. Please check your input."
                    </div>
                }

                @if (Model.SolvedPuzzle != null)
                {
                    <h4 class="mt-4">Solved Puzzle:</h4>
                    <table class="table table-bordered mx-auto mt-3">
                        @for (int i = 0; i < solvedSize; i++)
                        {
                            <tr>
                                @for (int j = 0; j < solvedSize; j++)
                                {
                                    var isOriginal = !string.IsNullOrWhiteSpace(Model.InputPuzzle?[i][j]);
                                    string diagClass = "";
                                    if (Model.SelectedType == "Diagonal")
                                    {
                                        if (i == j) diagClass = "diagonal";
                                        else if (i + j == solvedSize - 1) diagClass = "anti-diagonal";
                                    }

                                    <td class="solved-cell @(isOriginal ? "original-cell" : "filled-cell") @diagClass">
                                        @Model.SolvedPuzzle[i, j]
                                    </td>
                                }
                            </tr>
                        }
                    </table>
                }
            </div>
        </div>
    </div>
</div>

<footer class="text-center mt-4">
    &copy; 2025 SudokuSolver | Built with ASP.NET Razor Pages
</footer>
